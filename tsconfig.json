{
  "extends": "@equisoft/typescript-config/tsconfig.standards.json",
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "types": ["node", "jest"],
    "noEmitOnError": true,
    "rootDir": "./src",
    "outDir": "dist",
    "declaration": true,
    "declarationDir": "dist"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "dist",
    "node_modules"
  ]
}
